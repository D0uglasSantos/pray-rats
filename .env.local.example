# =============================================================================
# Pray Rats — variáveis de ambiente
# Copie: cp .env.local.example .env.local
# =============================================================================

# ─── Obrigatórias (dev e produção) ───────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# URL pública do frontend (sem barra final)
# Dev:  http://localhost:3000
# Prod: https://pray-rats.vercel.app  (ou domínio customizado)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Obrigatória no servidor (nunca expor no client) ─────────────────────────

# Usada em Server Actions admin (signup, push, testes de integração/E2E)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# ─── Web Push — opcional (notificações no perfil) ────────────────────────────
# Gere com: npx web-push generate-vapid-keys

NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:seu@email.com

# ─── Sentry — opcional (monitoramento de erros) ──────────────────────────────

SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Upload de source maps no build (opcional):
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# ─── CI / E2E — só GitHub Actions ou testes locais ─────────────────────────

# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3100

# ─── Automáticas na Vercel (não precisa definir manualmente) ─────────────────
# VERCEL_URL — fallback de NEXT_PUBLIC_APP_URL se omitido
# VERCEL_ENV  — production | preview | development

# =============================================================================
# Supabase Dashboard (sem CLI) — ver README seção "Supabase Auth"
# =============================================================================
#
# Authentication → URL Configuration
#   Site URL = NEXT_PUBLIC_APP_URL
#   Redirect URLs:
#     {APP_URL}/auth/callback
#     {APP_URL}/reset-password
#     http://localhost:3000/auth/callback
#     http://localhost:3000/reset-password
#
# Authentication → Emails → SMTP (opcional)
#   Sem SMTP: Supabase envia e-mails de auth pelo serviço padrão (MVP).
#   Para mais volume: Resend, Gmail, SendGrid, etc.
#
# Storage → buckets públicos: avatars, checkins (ver README)
#
# Login social (opcional):
#   1. Authentication → Providers → Google / Apple
#   2. src/lib/auth-features.ts → SOCIAL_AUTH_ENABLED = true
#   3. Descomente SocialAuthButtons em login-form.tsx e signup-form.tsx
