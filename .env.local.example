# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# App — URL pública do frontend (obrigatório em produção)
# Dev: http://localhost:3000
# Prod: https://seudominio.com (sem barra final)
# Se omitido na Vercel, usa VERCEL_URL como fallback
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web Push (VAPID) — gere com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:seu@email.com

# ─── Checklist produção (Supabase Dashboard, sem SQL) ───────────────────────
#
# Authentication → URL Configuration
#   Site URL: mesmo valor de NEXT_PUBLIC_APP_URL
#   Redirect URLs (adicionar todas):
#     https://seudominio.com/auth/callback
#     https://seudominio.com/reset-password
#     http://localhost:3000/auth/callback          (dev)
#     http://localhost:3000/reset-password         (dev)
#
# Authentication → Emails → SMTP Settings
#   Configure SMTP customizado (Resend, SendGrid, etc.) para e-mails de
#   recuperação de senha chegarem em produção.
#
# Vercel → Settings → Environment Variables
#   NEXT_PUBLIC_APP_URL=https://seudominio.com
#   (demais variáveis acima para Production)
